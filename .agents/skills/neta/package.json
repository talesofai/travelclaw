{
  "name": "@neta/skills-neta",
  "version": "0.5.0",
  "description": "A skill for interacting with Neta API to generate images, videos, songs, and manage characters/elements.",
  "type": "module",
  "author": "Neta Team",
  "license": "MIT",
  "keywords": [
    "neta",
    "api",
    "skill",
    "pi-agent",
    "image-generation",
    "video-generation",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/talesofai/neta-skills.git"
  },
  "bugs": {
    "url": "https://github.com/talesofai/neta-skills/issues"
  },
  "homepage": "https://github.com/talesofai/neta-skills#readme",
  "bin": {
    "neta-skills": "bin/cli.js"
  },
  "scripts": {
    "dev": "NODE_ENV=development node src/cli.ts",
    "start": "node bin/cli.js",
    "type-check": "tsc --noEmit",
    "build": "rimraf bin && tsc",
    "postbuild": "node scripts/postbuild.js",
    "validate": "bash scripts/validate-skill.sh"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "@sinclair/typebox": "^0.34.48",
    "axios": "^1.7.9",
    "commander": "^14.0.0",
    "dotenv": "^16.4.7",
    "dotenv-flow": "^4.1.0",
    "qs": "^6.15.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/qs": "^6.14.0",
    "glob": "^13.0.6"
  }
}
